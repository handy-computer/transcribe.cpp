{
  "_comment": [
    "Parakeet TDT tolerances for C++ vs NeMo (canonical reference).",
    "",
    "Reference: NeMo 2.7.x, nvidia/parakeet-tdt-0.6b-v2, CPU fp32.",
    "C++: ggml CPU or Metal, weights as fp32 in GGUF.",
    "",
    "Mel frontend: C++ uses fp64 STFT, NeMo uses torch fp32 STFT.",
    "This produces ~5 max_abs in edge mel bins (0-2, 126-127).",
    "Conv subsampling amplifies to ~2000 in pre_encode, but 24 layers",
    "of conformer normalization attenuate it to ~0.05 by enc.final.",
    "",
    "Validation strategy:",
    "  - GATE tensors have tight thresholds that catch real bugs",
    "    (wrong weights, wrong ops, wrong layer order).",
    "  - INFORMATIONAL tensors use wide thresholds because their",
    "    divergence is dominated by the known mel frontend difference,",
    "    not implementation bugs. They're still reported so you can",
    "    spot regressions, but they don't fail the gate.",
    "  - Transcript match is the ultimate behavioral gate (checked",
    "    separately, not by compare_tensors.py)."
  ],

  "enc.mel.in":            {"max_abs": 10.0,   "mean_abs": 0.1,    "_role": "informational"},
  "enc.pre_encode.out":    {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.pos_emb":           {"max_abs": 1e-3,   "mean_abs": 1e-5,   "_role": "gate"},

  "enc.block.0.ff1":       {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.0.attn":      {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.0.conv":      {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.0.ff2":       {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.0.out":       {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.12.out":      {"max_abs": 5000,   "mean_abs": 200,    "_role": "informational"},
  "enc.block.23.out":      {"max_abs": 0.5,    "mean_abs": 0.01,   "_role": "gate"},

  "enc.final":             {"max_abs": 0.5,    "mean_abs": 0.01,   "_role": "gate"},

  "dec.enc_out":           {"max_abs": 0.5,    "mean_abs": 0.01,   "_role": "gate"},
  "dec.embed.0":           {"max_abs": 1e-6,   "mean_abs": 1e-7,   "_role": "gate"},
  "dec.lstm.0.h.0":        {"max_abs": 1e-3,   "mean_abs": 1e-5,   "_role": "gate"},
  "dec.lstm.0.c.0":        {"max_abs": 1e-3,   "mean_abs": 1e-5,   "_role": "gate"},
  "dec.lstm.1.h.0":        {"max_abs": 1e-3,   "mean_abs": 1e-5,   "_role": "gate"},
  "dec.lstm.1.c.0":        {"max_abs": 1e-3,   "mean_abs": 1e-5,   "_role": "gate"},
  "dec.joint.0":           {"max_abs": 200,    "mean_abs": 200,    "_role": "informational"}
}
